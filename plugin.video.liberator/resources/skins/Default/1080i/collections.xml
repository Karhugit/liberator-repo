<?xml version="1.0" encoding="UTF-8"?>
<window>
    <controls>
        <!-- Background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF000000">liberator_common/white.png</texture>
            <animation effect="fade" end="80" time="120">WindowOpen</animation>
        </control>
        
        <!-- Main Window Group -->
        <control type="group">
            <top>92</top>
            <left>92</left>
            <animation effect="fade" end="100" time="200">WindowOpen</animation>
            
            <!-- Window Background Base -->
            <control type="image">
                <left>-2</left>
                <top>-2</top>
                <width>1736</width>
                <height>907</height>
                <texture colordiffuse="FFCCCCCC" border="30">liberator_common/circle.png</texture>
            </control>
            <control type="image">
                <width>1732</width>
                <height>903</height>
                <texture colordiffuse="FF1F2020" border="30">liberator_common/circle.png</texture>
            </control>
            
            <!-- Title Section -->
            <control type="image">
                <left>12</left>
                <top>12</top>
                <width>40</width>
                <height>40</height>
                <align>left</align>
                <aligny>top</aligny>
                <aspectratio aligny="top">keep</aspectratio>
                <texture colordiffuse="FFCCCCCC">liberator_common/liberator.png</texture>
            </control>
            <control type="label">
                <width max="1635">auto</width>
                <top>12</top>
                <left>60</left>
                <height>20</height>
                <font>font12</font>
                <textcolor>FFCCCCCC</textcolor>
                <shadowcolor>FF000000</shadowcolor>
                <align>left</align>
                <label>[UPPERCASE][B]MOVIE COLLECTIONS[/B][/UPPERCASE]</label>
            </control>

            <!-- LEFT PANEL: Collections List -->
            <control type="fixedlist" id="2000">
                <left>20</left>
                <top>60</top>
                <width>700</width>
                <height>820</height>
                <onup>2000</onup>
                <ondown>2000</ondown>
                <onleft>2000</onleft>
                <onright>2001</onright>
                <scrolltime tween="sine">200</scrolltime>
                <orientation>vertical</orientation>
                
                <itemlayout height="100" width="700">
                    <control type="label">
                        <left>15</left>
                        <top>10</top>
                        <width>670</width>
                        <height>40</height>
                        <font>font13</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <aligny>center</aligny>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <control type="label">
                        <left>15</left>
                        <top>50</top>
                        <width>670</width>
                        <height>40</height>
                        <font>font11</font>
                        <textcolor>FF888888</textcolor>
                        <aligny>center</aligny>
                        <label>$INFO[ListItem.Property(item_count)]</label>
                    </control>
                </itemlayout>

                <focusedlayout height="100" width="700">
                    <control type="image">
                        <width>700</width>
                        <height>100</height>
                        <texture colordiffuse="FFAA00FF" border="10">liberator_common/white.png</texture>
                    </control>
                    <control type="label">
                        <left>15</left>
                        <top>10</top>
                        <width>670</width>
                        <height>40</height>
                        <font>font13</font>
                        <textcolor>FFFFFFFF</textcolor>
                        <aligny>center</aligny>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <control type="label">
                        <left>15</left>
                        <top>50</top>
                        <width>670</width>
                        <height>40</height>
                        <font>font11</font>
                        <textcolor>FFEEEEEE</textcolor>
                        <aligny>center</aligny>
                        <label>$INFO[ListItem.Property(item_count)]</label>
                    </control>
                </focusedlayout>
            </control>

            <!-- RIGHT PANEL: Movies in Collection -->
            <control type="fixedlist" id="2001">
                <left>750</left>
                <top>60</top>
                <width>950</width>
                <height>820</height>
                <onup>2001</onup>
                <ondown>2001</ondown>
                <onleft>2000</onleft>
                <onright>2001</onright>
                <scrolltime tween="sine">200</scrolltime>
                <orientation>vertical</orientation>
                
                <itemlayout height="70" width="950">
                    <control type="label">
                        <left>15</left>
                        <top>0</top>
                        <width>800</width>
                        <height>70</height>
                        <font>font12</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <aligny>center</aligny>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <control type="label">
                        <left>820</left>
                        <top>0</top>
                        <width>120</width>
                        <height>70</height>
                        <font>font12</font>
                        <textcolor>FFAAAAAA</textcolor>
                        <aligny>center</aligny>
                        <label>$INFO[ListItem.Property(year)]</label>
                    </control>
                </itemlayout>

                <focusedlayout height="70" width="950">
                    <control type="image">
                        <width>950</width>
                        <height>70</height>
                        <texture colordiffuse="FFAA00FF" border="10">liberator_common/white.png</texture>
                    </control>
                    <control type="label">
                        <left>15</left>
                        <top>0</top>
                        <width>800</width>
                        <height>70</height>
                        <font>font12</font>
                        <textcolor>FFFFFFFF</textcolor>
                        <aligny>center</aligny>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <control type="label">
                        <left>820</left>
                        <top>0</top>
                        <width>120</width>
                        <height>70</height>
                        <font>font12</font>
                        <textcolor>FFEEEEEE</textcolor>
                        <aligny>center</aligny>
                        <label>$INFO[ListItem.Property(year)]</label>
                    </control>
                </focusedlayout>
            </control>

        </control>
    </controls>
</window>
